# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=evlens
POSTGRES_USER=evlens
POSTGRES_PASSWORD=changeme

# ── Security ──────────────────────────────────────────────────────────────────
# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_hex(32))"
# Generate ENCRYPTION_KEY with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# SECRET_KEY must also match BRIDGE_SECRET in your Cloudflare Worker settings
SECRET_KEY=changeme-generate-a-real-one
ENCRYPTION_KEY=changeme-generate-a-real-fernet-key=

# Set only on first run to create the admin account. Remove after first login.
FIRST_RUN_ADMIN_PASSWORD=

# ── Tesla Fleet API ───────────────────────────────────────────────────────────
# Register at https://developer.tesla.com
TESLA_CLIENT_ID=
TESLA_CLIENT_SECRET=

# OAuth bridge URL — receives Tesla's callback and redirects back to APP_PUBLIC_URL.
# Default points to the hosted ev-lens bridge on Cloudflare Workers.
OAUTH_BRIDGE_URL=https://auth.ev-lens.com

# Public URL of this EV Lens instance — sent to the bridge so it knows where to redirect back.
# Local install: http://localhost:8000
# Exposed install (Tailscale, Cloudflare Tunnel, etc.): https://evlens.yourdomain.com
APP_PUBLIC_URL=http://localhost:8000

# ── Ports ─────────────────────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000

# ── Logging ───────────────────────────────────────────────────────────────────
# debug | info | warning | error
LOG_LEVEL=info
